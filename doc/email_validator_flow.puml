@startuml email_validator_flow
skinparam conditionStyle inside
skinparam ActivityBackgroundColor #f1f5f9
skinparam ActivityBorderColor #475569
skinparam ActivityFontName "Helvetica"
skinparam ActivityFontSize 12
skinparam ArrowColor #64748b
skinparam ConditionBackgroundColor #f8fafc
skinparam ConditionBorderColor #64748b

title Flowchart of the Rust Email Validator

start

:Parse CLI subcommand (clap);

if (Subcommand?) then (api)
  partition "API Server Mode" {
    :Parse ApiArgs (bind_addr, verbose);
    :Bind TCP listener at bind_addr
    (default: 0.0.0.0:8080 or $BIND_ADDR);
    :Start axum HTTP server;
    :Wait for requests (loop);
    if (GET /health?) then (yes)
      :Return {"status":"ok","version":"..."};
    elseif (GET /validate?email=...&method=...) then (yes)
      :Parse query params → single email;
    elseif (POST /validate) then (yes)
      :Parse JSON body (axum Json extractor);
      if (emails is empty?) then (yes)
        :Return 400 {"error":"email list is empty"};
        stop
      elseif (emails > 1000?) then (yes)
        :Return 400 {"error":"too many emails, max 1000"};
        stop
      else (no)
        :Deduplicate (case-insensitive, to_lowercase);
      endif
    else (no)
      :Return 404;
    endif
    :Run precheck → validation pipeline;
    :Return JSON with summary
    (total, valid_count, invalid_count,
     catch_all_count, results[]);
    detach
  }
  stop
else (run)
  :Parse RunArgs (input, output, format, method, ...);
  :Determine 'is_quiet' ((Format == Gophish OR Json) AND NOT Verbose);
endif

partition "Phase 0: Data Ingestion" {
  if (Input file (-i) provided?) then (yes)
    :Read entire file content into memory;
  else (no)
    :Read data from STDIN (pipe);
  endif

  if (Input data empty?) then (yes)
    :Log error to STDERR and exit program;
    stop
  else (no)
  endif

  :Extract all valid emails using robust Regex;
  :Deduplicate and sort extracted emails;
  :Initialize empty set 'wildcard_domains';
}

if (Method == SMTP AND Wildcard detection enabled?) then (yes)
  partition "Phase 1: Wildcard Pre-Check" {
    :Extract unique domains from unique emails;
    if (NOT is_quiet?) then (yes)
      :Log "Running Pre-Check" to STDERR;
    else (no)
    endif
    while (For each unique domain) is (Next domain)
      :Generate fake email (dlfAxs...@domain);
      :Execute async SMTP/MX check;
      if (Status == Reachable::Safe OR Risky?) then (yes)
        :Add domain to 'wildcard_domains' set;
        if (NOT is_quiet?) then (yes)
          :Log warning to STDERR: "[!] Wildcard detected";
        else (no)
        endif
      else (no)
      endif
    endwhile (No more domains)
  }
else (no)
  :Skip Phase 1;
endif

partition "Phase 2: Validating Email List" {
  :Initialize empty vector 'validation_results';
  if (NOT is_quiet?) then (yes)
    :Log "Validating Email List" to STDERR;
  else (no)
  endif

  while (For each unique email) is (Next email)
    if (Method == Regex?) then (yes)
      :Check Syntax via Regex;
    elseif (Method == MX?) then (yes)
      :Check Syntax via Regex;
      :Execute DNS MX Lookup via Hickory;
    else (Method == SMTP)
      :Create CheckEmailInput object;
      :Execute async full SMTP handshake
      via check-if-email-exists;
    endif

    :Push ValidationResult {email, valid, catch_all};
    if (NOT is_quiet?) then (yes)
      if (valid AND Catch-All?) then (yes)
        :Log to STDERR: [+] Email in Yellow;
      elseif (valid?) then (yes)
        :Log to STDERR: [+] Email in Green;
      else (no)
        :Log to STDERR: [-] Email in Red;
      endif
    else (no)
    endif
  endwhile (No more emails left)
}

partition "Phase 3: Handle Output (Unified Stream)" {
  if (Output file (-o) provided?) then (yes)
    :Set Output Stream = File;
  else (no)
    :Set Output Stream = STDOUT;
  endif

  if (JSON mode (-j)?) then (yes)
    :Serialize ALL results as JSON array to Output Stream;
    note right: includes valid=true + valid=false
  elseif (Format == Gophish?) then (yes)
    :Write valid emails as CSV to Output Stream;
  else (List)
    :Write valid emails as text list to Output Stream;
  endif

  note right
    Writes are checked for errors.
    Quietly exit loop if pipe is broken.
  end note

  if (Output file (-o) provided AND NOT is_quiet?) then (yes)
    :Log success message to STDERR;
  else (no)
  endif
}

stop

@enduml